# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://posuser:pospassword@localhost:5432/posdb"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# ─── Security ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─── CORS ────────────────────────────────────────────────────────────────────
# For production, set to your frontend domain: https://yourdomain.com
CORS_ORIGIN=*
