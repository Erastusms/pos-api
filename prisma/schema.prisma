generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User & Identity ─────────────────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  pin       String?
  isActive  Boolean   @default(true)
  roleId    Int
  outletId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  role                 Role                  @relation(fields: [roleId], references: [id])
  outlet               Outlet?               @relation(fields: [outletId], references: [id])
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  inventoryAdjustments InventoryAdjustment[]
  carts                Cart[]
  orders               Order[]

  @@index([email])
  @@index([outletId])
  @@index([roleId])
  @@map("users")
}

// ─── Role & Permission (RBAC) ─────────────────────────────────────────────────

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  displayName String
  description String?

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          Int     @id @default(autoincrement())
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Outlet (Multi-branch) ────────────────────────────────────────────────────

model Outlet {
  id        String    @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  taxNumber String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users          User[]
  categories     Category[]
  products       Product[]
  inventoryItems InventoryItem[]
  employees      Employee[]
  settings       OutletSettings?
  businessHours  OutletBusinessHour[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  carts          Cart[]
  discounts      Discount[]
  orders         Order[]
  receipts       Receipt[]

  @@map("outlets")
}

// ─── Auth Tokens ──────────────────────────────────────────────────────────────

model RefreshToken {
  id         String   @id @default(cuid())
  token      String   @unique
  userId     String
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Audit Trail ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Employee ─────────────────────────────────────────────────────────────────

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

model Employee {
  id               String           @id @default(cuid())
  outletId         String
  name             String
  email            String?
  phone            String?
  pin              String?
  position         String
  employmentStatus EmploymentStatus @default(ACTIVE)
  hireDate         DateTime         @db.Date
  salary           Decimal?         @db.Decimal(15, 2)
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  outlet Outlet  @relation(fields: [outletId], references: [id])
  shifts Shift[]

  @@index([outletId])
  @@index([employmentStatus])
  @@map("employees")
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
  CUSTOM
}

model Shift {
  id         String    @id @default(cuid())
  employeeId String
  date       DateTime  @db.Date
  startTime  String
  endTime    String
  type       ShiftType @default(CUSTOM)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("shifts")
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String
  description String?
  imageUrl    String?
  parentId    String?
  outletId    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  outlet   Outlet?    @relation(fields: [outletId], references: [id])
  products Product[]

  @@unique([slug, outletId])
  @@index([parentId])
  @@index([outletId])
  @@index([isActive])
  @@map("categories")
}

enum ProductType {
  SINGLE
  VARIANT
}

model Product {
  id          String      @id @default(cuid())
  outletId    String
  categoryId  String?
  name        String
  description String?
  sku         String
  barcode     String?
  price       Decimal     @default(0) @db.Decimal(15, 2)
  cost        Decimal     @default(0) @db.Decimal(15, 2)
  type        ProductType @default(SINGLE)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  category       Category?             @relation(fields: [categoryId], references: [id])
  outlet         Outlet                @relation(fields: [outletId], references: [id])
  variants       ProductVariant[]
  modifierGroups ProductModifierGroup[]
  images         ProductImage[]
  inventoryItem       InventoryItem?
  purchaseOrderItems  PurchaseOrderItem[]
  cartItems           CartItem[]
  discountProducts    DiscountProduct[]
  orderItems          OrderItem[]

  @@unique([sku, outletId])
  @@index([categoryId])
  @@index([outletId])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  sku        String
  barcode    String?
  price      Decimal? @db.Decimal(15, 2)
  cost       Decimal? @db.Decimal(15, 2)
  attributes Json?
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images  ProductImage[]
  cartItems CartItem[]

  @@unique([sku, productId])
  @@index([productId])
  @@map("product_variants")
}

model ProductModifierGroup {
  id          String   @id @default(cuid())
  productId   String
  name        String
  description String?
  isRequired  Boolean  @default(false)
  minSelect   Int      @default(0)
  maxSelect   Int      @default(1)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifiers ProductModifier[]

  @@index([productId])
  @@map("product_modifier_groups")
}

model ProductModifier {
  id              String   @id @default(cuid())
  modifierGroupId String
  name            String
  price           Decimal  @default(0) @db.Decimal(15, 2)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  modifierGroup ProductModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  cartItemModifiers  CartItemModifier[]
  orderItemModifiers OrderItemModifier[]

  @@index([modifierGroupId])
  @@map("product_modifiers")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  variantId String?
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@map("product_images")
}

// ─── Inventory ────────────────────────────────────────────────────────────────

enum AdjustmentType {
  INITIAL
  PURCHASE_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  SALE_OUT
  RETURN_IN
  VOID
}

model InventoryItem {
  id        String   @id @default(cuid())
  productId String   @unique
  outletId  String
  quantity  Decimal  @default(0) @db.Decimal(10, 3)
  unit      String   @default("pcs")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product     Product               @relation(fields: [productId], references: [id])
  outlet      Outlet                @relation(fields: [outletId], references: [id])
  adjustments InventoryAdjustment[]
  costLayers  InventoryCostLayer[]

  @@index([outletId])
  @@map("inventory_items")
}

model InventoryAdjustment {
  id              String         @id @default(cuid())
  inventoryItemId String
  type            AdjustmentType
  quantity        Decimal        @db.Decimal(10, 3)
  quantityBefore  Decimal        @db.Decimal(10, 3)
  quantityAfter   Decimal        @db.Decimal(10, 3)
  costPerUnit     Decimal?       @db.Decimal(15, 4)
  totalCost       Decimal?       @db.Decimal(15, 4)
  notes           String?
  reference       String?
  userId          String?
  createdAt       DateTime       @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_adjustments")
}

model InventoryCostLayer {
  id              String   @id @default(cuid())
  inventoryItemId String
  quantityIn      Decimal  @db.Decimal(10, 3)
  quantityLeft    Decimal  @db.Decimal(10, 3)
  costPerUnit     Decimal  @db.Decimal(15, 4)
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId, createdAt])
  @@index([inventoryItemId, quantityLeft])
  @@map("inventory_cost_layers")
}

// ─── Outlet Settings & Business Hours ────────────────────────────────────────

/// Settings operasional outlet — disimpan sebagai satu row per outlet.
/// Menggunakan pendekatan row per outlet (bukan JSON column) agar bisa di-index
/// dan di-validate di level DB.
model OutletSettings {
  id              String  @id @default(cuid())
  outletId        String  @unique
  /// PPN dalam persen, e.g. 11.00 untuk 11%
  taxRate         Decimal @default(0)   @db.Decimal(5, 2)
  taxName         String  @default("PPN")
  /// Service charge dalam persen
  serviceCharge   Decimal @default(0)   @db.Decimal(5, 2)
  /// Pembulatan harga: NONE | UP | DOWN | NEAREST
  rounding        String  @default("NONE")
  /// Nilai pembulatan, e.g. 100, 500, 1000
  roundingValue   Int     @default(0)
  /// Footer struk / receipt
  receiptFooter   String?
  /// URL logo untuk struk
  receiptLogoUrl  String?
  /// Mata uang, e.g. "IDR"
  currency        String  @default("IDR")
  /// Timezone, e.g. "Asia/Jakarta"
  timezone        String  @default("Asia/Jakarta")
  updatedAt       DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@map("outlet_settings")
}

/// Jam operasional per hari per outlet
model OutletBusinessHour {
  id        String   @id @default(cuid())
  outletId  String
  /// 0 = Minggu, 1 = Senin, ..., 6 = Sabtu
  dayOfWeek Int
  isOpen    Boolean  @default(true)
  openTime  String   @default("08:00")   /// "HH:MM"
  closeTime String   @default("22:00")   /// "HH:MM"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id], onDelete: Cascade)

  @@unique([outletId, dayOfWeek])
  @@index([outletId])
  @@map("outlet_business_hours")
}

// ─── Discount ─────────────────────────────────────────────────────────────────

enum DiscountType {
  PERCENTAGE    /// Potongan dalam persen, e.g. 10% → value = 10
  FIXED_AMOUNT  /// Potongan nominal rupiah, e.g. Rp 10.000 → value = 10000
}

enum DiscountScope {
  PER_ITEM  /// Berlaku untuk produk tertentu yang didaftarkan di DiscountProduct
  PER_BILL  /// Berlaku untuk seluruh bill
}

model Discount {
  id          String        @id @default(cuid())
  outletId    String
  name        String
  code        String?       /// Kode promo opsional, e.g. "MERDEKA17"
  description String?
  type        DiscountType
  scope       DiscountScope
  /// Nilai persen (0-100) atau nominal (Rp) tergantung type
  value       Decimal       @db.Decimal(10, 2)
  /// Minimum subtotal agar diskon berlaku
  minPurchase Decimal?      @db.Decimal(15, 2)
  /// Cap jumlah diskon maksimal (terutama untuk PERCENTAGE)
  maxDiscount Decimal?      @db.Decimal(15, 2)
  isActive    Boolean       @default(true)
  startAt     DateTime?
  endAt       DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  outlet   Outlet            @relation(fields: [outletId], references: [id])
  products DiscountProduct[]
  carts    Cart[]
  orders   Order[]

  @@unique([code, outletId])
  @@index([outletId, isActive])
  @@index([code])
  @@map("discounts")
}

/// Junction: produk mana saja yang berlaku untuk diskon PER_ITEM
model DiscountProduct {
  discountId String
  productId  String

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([discountId, productId])
  @@index([discountId])
  @@index([productId])
  @@map("discount_products")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

enum CartStatus {
  ACTIVE       /// Sedang diproses kasir
  CHECKED_OUT  /// Sudah dikonversi ke Order
  ABANDONED    /// Dibatalkan / ditinggal
}

model Cart {
  id         String     @id @default(cuid())
  outletId   String
  userId     String
  discountId String?    /// FK ke Discount yang sedang diterapkan (opsional)
  notes      String?
  status     CartStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  outlet   Outlet     @relation(fields: [outletId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  discount Discount?  @relation(fields: [discountId], references: [id], onDelete: SetNull)
  items    CartItem[]
  order    Order?

  @@index([outletId, userId, status])
  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  /// Jumlah item — mendukung desimal untuk produk curah (misal 0.5 kg)
  quantity  Decimal @db.Decimal(10, 3)
  /// Snapshot harga satuan saat item ditambahkan (tidak berubah meski harga produk berubah)
  unitPrice Decimal @db.Decimal(15, 2)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart      Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product            @relation(fields: [productId], references: [id])
  variant   ProductVariant?    @relation(fields: [variantId], references: [id], onDelete: SetNull)
  modifiers CartItemModifier[]

  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model CartItemModifier {
  id         String  @id @default(cuid())
  cartItemId String
  modifierId String
  /// Snapshot nama modifier saat ditambahkan
  name       String
  /// Snapshot harga modifier saat ditambahkan
  price      Decimal @db.Decimal(15, 2)

  cartItem CartItem        @relation(fields: [cartItemId], references: [id], onDelete: Cascade)
  modifier ProductModifier @relation(fields: [modifierId], references: [id])

  @@index([cartItemId])
  @@map("cart_item_modifiers")
}

// ─── Order ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  PENDING    /// Baru dibuat, menunggu pembayaran
  PAID       /// Sudah dibayar (oleh Payment module)
  DONE       /// Selesai / sudah diserahkan ke pelanggan
  VOID       /// Dibatalkan
}

model Order {
  id          String      @id @default(cuid())
  /// Format: TRX-YYYYMMDD-XXXX — auto-generated, unik per outlet per hari
  orderNumber String
  outletId    String
  /// Kasir yang membuat order
  userId      String
  /// Cart asal — UNIQUE: satu cart hanya bisa di-checkout sekali
  cartId      String?     @unique
  /// FK ke Discount (untuk audit, nullable jika diskon dihapus)
  discountId  String?

  status      OrderStatus @default(PENDING)
  notes       String?

  // ── Financial snapshot (immutable setelah order dibuat) ───────────────────
  subtotal            Decimal @db.Decimal(15, 2)
  discountAmount      Decimal @default(0) @db.Decimal(15, 2)
  discountedSubtotal  Decimal @db.Decimal(15, 2)
  serviceChargeAmount Decimal @default(0) @db.Decimal(15, 2)
  taxAmount           Decimal @default(0) @db.Decimal(15, 2)
  roundingAmount      Decimal @default(0) @db.Decimal(15, 2)
  total               Decimal @db.Decimal(15, 2)

  // ── Discount snapshot (readable meski diskon dihapus) ────────────────────
  discountName  String?
  discountCode  String?
  discountType  String?   /// 'PERCENTAGE' | 'FIXED_AMOUNT'
  discountScope String?   /// 'PER_ITEM' | 'PER_BILL'
  discountValue Decimal?  @db.Decimal(10, 2)

  // ── Lifecycle timestamps ──────────────────────────────────────────────────
  paidAt      DateTime?
  completedAt DateTime?
  voidedAt    DateTime?
  voidReason  String?
  voidedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet   Outlet     @relation(fields: [outletId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  cart     Cart?      @relation(fields: [cartId], references: [id], onDelete: SetNull)
  discount Discount?  @relation(fields: [discountId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  receipt  Receipt?

  @@unique([orderNumber, outletId])
  @@index([outletId, status])
  @@index([outletId, createdAt])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String

  /// FK nullable — produk mungkin soft-deleted di kemudian hari
  productId String?
  variantId String?

  // ── Product snapshot (immutable) ─────────────────────────────────────────
  productName String
  productSku  String
  variantName String?

  quantity  Decimal @db.Decimal(10, 3)
  unitPrice Decimal @db.Decimal(15, 2)
  /// Diskon per-item dari PER_ITEM discount (jika berlaku)
  itemDiscountAmount Decimal @default(0) @db.Decimal(15, 2)
  /// lineTotal = (unitPrice + Σ modifierPrice) × qty — tidak termasuk diskon item level
  lineTotal Decimal @db.Decimal(15, 2)
  notes     String?

  createdAt DateTime @default(now())

  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemModifier {
  id          String @id @default(cuid())
  orderItemId String

  /// FK nullable — modifier mungkin soft-deleted di kemudian hari
  modifierId String?

  // ── Modifier snapshot (immutable) ────────────────────────────────────────
  name  String
  price Decimal @db.Decimal(15, 2)

  orderItem OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier  ProductModifier? @relation(fields: [modifierId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@map("order_item_modifiers")
}

// ─── Receipt ──────────────────────────────────────────────────────────────────

enum ReceiptStatus {
  QUEUED      /// Job PDF sudah antri di queue
  GENERATING  /// Sedang di-generate oleh worker
  READY       /// PDF siap didownload
  FAILED      /// Gagal generate (akan di-retry)
}

model Receipt {
  id          String        @id @default(cuid())
  orderId     String        @unique   /// Satu order → satu receipt (upsert-able)
  outletId    String

  status      ReceiptStatus @default(QUEUED)
  /// Relative path / URL ke file PDF
  pdfUrl      String?
  /// ID job BullMQ — untuk tracking / cancellation
  jobId       String?
  /// Pesan error jika status = FAILED
  errorMessage String?
  /// Berapa kali sudah dicoba generate
  attempts    Int           @default(0)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  outlet Outlet @relation(fields: [outletId], references: [id])

  @@index([outletId])
  @@index([status])
  @@map("receipts")
}

// ─── Supplier & Purchase Order ────────────────────────────────────────────────

model Supplier {
  id          String    @id @default(cuid())
  outletId    String
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  outlet         Outlet          @relation(fields: [outletId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([outletId])
  @@index([isActive])
  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT      /// Baru dibuat, belum dikirim ke supplier
  ORDERED    /// Sudah dipesan / dikirim ke supplier
  PARTIAL    /// Sebagian barang sudah diterima
  RECEIVED   /// Semua barang sudah diterima
  CANCELLED  /// Dibatalkan
}

model PurchaseOrder {
  id            String              @id @default(cuid())
  outletId      String
  supplierId    String
  orderNumber   String              /// Auto-generated: PO-YYYYMMDD-XXXX
  status        PurchaseOrderStatus @default(DRAFT)
  notes         String?
  orderedAt     DateTime?           /// Tanggal PO dikirim ke supplier
  expectedAt    DateTime?           /// Estimasi tanggal terima
  receivedAt    DateTime?           /// Tanggal semua item diterima
  totalAmount   Decimal             @default(0) @db.Decimal(15, 2)
  createdById   String?             /// userId yang membuat
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  outlet    Outlet              @relation(fields: [outletId], references: [id])
  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]

  @@unique([orderNumber, outletId])
  @@index([outletId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  productId        String
  /// Jumlah yang dipesan
  quantity         Decimal @db.Decimal(10, 3)
  unit             String  @default("pcs")
  costPerUnit      Decimal @db.Decimal(15, 4)
  totalCost        Decimal @db.Decimal(15, 2)
  /// Jumlah yang sudah diterima (untuk partial receive)
  receivedQuantity Decimal @default(0) @db.Decimal(10, 3)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}
